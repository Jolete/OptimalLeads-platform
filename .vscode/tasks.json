                                "-NoProfile",
                                "-ExecutionPolicy",
                                "Bypass",
                                "-File",
                                "${workspaceFolder}\\scripts\\bootstrap-optimalleads-env.ps1"
                        ],
                        "problemMatcher": []
                },
                {
                        "label": "Start OptimalLeads Workspace",
                        "type": "shell",
                        "command": "powershell",
                        "args": [
                                "-NoProfile",
                                "-ExecutionPolicy",
                                "Bypass",
                                "-File",
                                "${workspaceFolder}\\.vscode\\start-workspace.ps1"
                        ],
