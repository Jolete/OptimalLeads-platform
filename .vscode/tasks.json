                        "args": [
                                "-NoProfile",
                                "-ExecutionPolicy",
                                "Bypass",
                                "-File",
                                "${workspaceFolder}\\scripts\\bootstrap-optimalleads-deps.ps1"
                        ],
                        "problemMatcher": []
                },
                {
                        "label": "bootstrap-optimalleads-env",
                        "type": "shell",
