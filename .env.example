APP_NAME=Chat API

# LLM / AI provider
LLM_PROVIDER=echo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Database provider for local dev / CI / production
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///./data/chat.db

# SQL Server local via Docker
SQL_SERVER_PORT=14331
MSSQL_PID=Developer
SA_PASSWORD=Password12345

# Optional: switch to SQL Server
# DATABASE_PROVIDER=sqlserver
# DATABASE_URL=Server=localhost;Database=quantion_chat;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False

# Optional secret-backed values (prefer CI/CD secret store instead of committing them)
# OPENAI_API_KEY=
