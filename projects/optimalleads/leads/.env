PERSISTENCE_PROVIDER=sqlserver
RESET_DATABASE_ON_STARTUP=true
OUTBOX_FLUSH_INTERVAL_SECONDS=1.0
BUSINESS_DATABASE_URL=mssql+aioodbc://sa:Password12345@localhost:1433/optimalleads_leads?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
OUTBOX_DATABASE_URL=
AUDIT_DATABASE_URL=
EVENTS_DATABASE_URL=
BROKER_PROVIDER=faststream_rabbitmq
BROKER_URL=amqp://guest:guest@localhost:5672/
BROKER_TOPIC=optimalleads.leads.events
BROKER_QUEUE=optimalleads.leads.events
BROKER_CONSUMER_GROUP=optimalleads-leads-group
TELEMETRY_SERVICE_NAME=optimalleads-leads
INTERNAL_SERVICE_PROTOCOL=rest
GRPC_LISTEN_HOST=127.0.0.1
GRPC_LISTEN_PORT=50051
LOG_HANDLERS=console,file
LOG_FILE_PATH=logs/leads.log