@host = http://127.0.0.1:8003
@json = application/json

### Health
GET {{host}}/health

### Snapshot (read model)
GET {{host}}/snapshot

### Snapshot alias (read model)
GET {{host}}/

### Ingest conversation-created event (event envelope sample)
POST {{host}}/ingest
Content-Type: {{json}}

{
  "event_id": "evt-001",
  "aggregate_id": "agg-001",
  "event_name": "ConversationCreated",
  "event_kind": "domain",
  "correlation_id": "corr-001",
  "causation_id": null,
  "occurred_at": "2026-07-01T00:00:00Z",
  "payload": {
    "conversation_id": "agg-001",
    "title": "Demo"
  }
}

### Ingest lead-created event (event envelope sample)
POST {{host}}/ingest
Content-Type: {{json}}

{
  "event_id": "evt-002",
  "aggregate_id": "lead-001",
  "event_name": "LeadCreated",
  "event_kind": "domain",
  "correlation_id": "corr-002",
  "causation_id": null,
  "occurred_at": "2026-07-01T00:00:00Z",
  "payload": {
    "lead_id": "lead-001",
    "name": "Demo lead"
  }
}

### Get outbox entries
GET {{host}}/outbox

### Flush outbox
POST {{host}}/outbox/flush
