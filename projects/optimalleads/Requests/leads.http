### Get all leads
GET {{host}}/leads

### Get lead by lead_id (lead_id is the resource id)
GET {{host}}/leads/{{leadId}}

### Update lead by lead_id (lead_id is the resource id)
PUT {{host}}/leads/{{leadId}}
Content-Type: {{json}}

{
  "name": "Lead CQRS 1 updated",
  "stage": "qualified",
  "notes": [
    "First note from PUT",
    "Second note from PUT"
  ],
  "correlation_id": "lead-001"
}

### Advance lead stage
POST {{host}}/leads/{{leadId}}/stage
Content-Type: {{json}}

{
  "stage": "contacted",
  "correlation_id": "lead-001"
}

### Delete lead by lead_id (lead_id is the resource id)
DELETE {{host}}/leads/{{leadId}}

### Get outbox entries
GET {{host}}/outbox

### Flush outbox
POST {{host}}/outbox/flush
